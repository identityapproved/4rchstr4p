alias zshconfig="nvim ${HOME}/.zshrc"
alias aliasconfig="nvim ${HOME}/.aliases"
alias aliases="ca ${HOME}/.aliases"
alias tmuxconfig="nvim ${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"
alias pushclip="tmux save-buffer ~/clipboard.txt"
alias srczsh='source ${HOME}/.zshrc'

alias q="exit"
alias rf="rm -rf"
alias c="clear"
alias l='lsd -l'
alias la='lsd -a'
alias lla='lsd -la'
alias lt='lsd --tree'
alias ..='cd ..'
alias ...='cd ../../'
alias ....='cd ../../../'
alias .....='cd ../../../../'

alias fman="compgen -c | fzf --tmux bottom,32%,100% --height 32% --layout reverse --border --no-preview | xargs man"
alias ftldr="compgen -c | fzf --tmux bottom,32%,100% --height 32% --layout reverse --border --no-preview | xargs tldr"

alias fcd="cd ~ && cd \$(fzf --tmux bottom,32%,100% --height 32% | sed 's/\/[^\/]*$//')"

alias v='nvim'
alias fv="nvim \$(fzf --tmux bottom,32%,100% --height 32%)"

alias yz='yazi'
alias lz='lazygit'

alias make="make -j\`nproc\`"
alias ninja="ninja -j\`nproc\`"
alias n="ninja"

alias tb="nc termbin.com 9999"
alias ca="bat"

# Get the error messages from journalctl
alias jctl="journalctl -p 3 -xb"

# Connect to OpenVPN config (runs in background)
openvpnconnect() {
  local ovpn_dir="$HOME/ovpns"
  [[ -d "$ovpn_dir" ]] || { echo "Directory not found: $ovpn_dir"; return 1; }
  local config
  config="$(find "$ovpn_dir" -maxdepth 1 -type f -name '*.ovpn' | sort | fzf --tmux bottom,32%,100% --height 32% --border --prompt='ovpn> ' --select-1 --exit-0)"
  [[ -n "$config" ]] || { echo "No config selected."; return 1; }
  sudo openvpn --daemon --config "$config"
}

# Disconnect (kill all openvpn processes)
alias openvpndisconnect='sudo killall openvpn'
